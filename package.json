{
  "name": "infinity-fetch",
  "version": "1.2.0",
  "description": "Configurable recursive/infinite fetch utility for paginated APIs. Works in Node.js and browsers.",
  "keywords": [
    "infinity",
    "fetch",
    "pagination",
    "recursive",
    "bitbucket"
  ],
  "homepage": "https://github.com/ElJijuna/infinity-fetch#readme",
  "bugs": {
    "url": "https://github.com/ElJijuna/infinity-fetch/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ElJijuna/infinity-fetch.git"
  },
  "license": "MIT",
  "author": "Ivan",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "docs": "typedoc",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typedoc": "^0.26.0",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    }
  }
}
